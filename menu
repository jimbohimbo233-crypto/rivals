-- Update formatEntriesForSave to include the full file structure
local function formatEntriesForSave(entriesList)
    local lines = {}
    for i, entry in ipairs(entriesList) do
        if i < #entriesList then
            table.insert(lines, entry .. ",")
        else
            table.insert(lines, entry)
        end
    end
    
    -- Return the FULL file content with proper structure
    return "local cheaters = [[" .. "\n" .. 
           table.concat(lines, "\n") .. "\n" .. 
           "]]\nreturn cheaters"
end

local function parseCheaterEntries(text)
    local map = {}
    
    -- Normalise line endings
    text = text:gsub("\r\n", "\n"):gsub("\r", "\n")
    
    -- Safer extraction: find [[ and ]] by position instead of pattern
    local startPos = text:find("%[%[")
    local endPos = text:find("%]%]", startPos and startPos + 2 or 1)
    
    if not startPos or not endPos then
        print("[Cheater List] Could not find [[ ]] delimiters in file")
        return map
    end
    
    local content = text:sub(startPos + 2, endPos - 1)

    for line in content:gmatch("[^\n]+") do
        line = line:match("^%s*(.-)%s*$")
        if line ~= "" then
            line = line:gsub(",$", "")

            local parts = {}
            for v in line:gmatch('[^,%[%]]+') do
                v = v:gsub('^%s*"', ''):gsub('"%s*$', ''):gsub("^%s*", ""):gsub("%s*$", "")
                if v ~= "" then
                    table.insert(parts, v)
                end
            end

            local uid = tonumber(parts[1])
            if uid then
                map[uid] = {}
                for i = 2, #parts do
                    table.insert(map[uid], parts[i])
                end
            end
        end
    end
    return map
end

-- Count entries (# doesn't work on hash maps)
local function countMap(t)
    local n = 0
    for _ in pairs(t) do n = n + 1 end
    return n
end

local function loadFromLocalFile()
    if isfile and isfile(LOCAL_FILE) then
        local success, content = pcall(readfile, LOCAL_FILE)
        if success and content and content ~= "" then
            print("[Cheater List] Attempting to load from local file...")
            local map = parseCheaterEntries(content)
            local count = countMap(map)
            if count > 0 then
                print("[Cheater List] Successfully loaded", count, "entries from local file")
                return map
            else
                print("[Cheater List] Local file exists but contains no valid entries")
            end
        end
    end
    return nil
end

local function loadFromGitHub()
    local success, raw = pcall(game.HttpGet, game, GITHUB_URL, true)
    if success and raw then
        print("[Cheater List] Loading from GitHub...")
        local map = parseCheaterEntries(raw)
        local count = countMap(map)
        if count > 0 then
            print("[Cheater List] Successfully loaded", count, "entries from GitHub")
            pcall(function()
                if writefile then
                    writefile(LOCAL_FILE, raw)
                    print("[Cheater List] Cached to local file")
                end
            end)
            return map
        else
            print("[Cheater List] GitHub returned data but parsed 0 entries")
        end
    else
        print("[Cheater List] GitHub fetch failed")
    end
    return nil
end


-- Update loadFromLocalFile and loadFromGitHub to handle full file structure
local function parseEntriesFromText(text)
    -- Extract content between [[ and ]]
    local content = text:match("%[%[\n?(.-)\n?%]%]") or ""
    content = content:gsub("\r", "")
    
    local entries = {}
    for line in content:gmatch("[^\n]+") do
        line = line:match("^%s*(.-)%s*$")
        if line ~= "" then
            -- Remove trailing comma if present
            line = line:gsub(",$", "")
            table.insert(entries, line)
        end
    end
    return entries
end

-- Update saveToLocalFile to save full structure
local function saveToLocalFile(entriesList)
    local fullContent = formatEntriesForSave(entriesList)
    writefile(LOCAL_FILE, fullContent)
    print("[Cheater List] Saved to local file:", LOCAL_FILE)
end

local function getCheaterList()
    -- Try local file first
    local entries = loadFromLocalFile()
    
    -- If local file is empty or doesn't exist, load from GitHub
    if not entries or #entries == 0 then
        entries = loadFromGitHub()
        -- If GitHub had data, save it locally with full structure
        if entries and #entries > 0 then
            saveToLocalFile(entries)
        end
    end
    
    -- If still no entries, return empty table
    if not entries then
        entries = {}
    end
    
    -- Build cache with userId keys for quick lookup
    CachedEntries = {}
    for _, entry in ipairs(entries) do
        local userId = entry:match("^%[(%d+),")
        if userId then
            CachedEntries[tonumber(userId)] = entry
        end
    end
    
    return entries
end

-- Update pushEntries to pass the full content to editFile
local function pushEntries(newReports)
    if isUpdating then return end
    isUpdating = true

    -- Get current entries (from local file or GitHub)
    local currentEntries = {}
    local localEntries = loadFromLocalFile()
    
    if localEntries and #localEntries > 0 then
        currentEntries = localEntries
    else
        currentEntries = loadFromGitHub() or {}
    end
    
    -- Parse existing entries into map
    local entriesMap = {}
    for _, entry in ipairs(currentEntries) do
        local userId = entry:match("^%[(%d+),")
        if userId then
            userId = tonumber(userId)
            -- Remove trailing comma for consistent storage
            entry = entry:gsub(",$", "")
            entriesMap[userId] = entry
        end
    end
    
    -- Update or add new entries
    for _, report in ipairs(newReports) do
        local userId = report:match("^%[(%d+),")
        if userId then
            userId = tonumber(userId)
            -- Remove trailing comma for consistent storage
            report = report:gsub(",$", "")
            entriesMap[userId] = report
        end
    end
    
    -- Convert back to list and sort
    local entriesList = {}
    for userId, entry in pairs(entriesMap) do
        table.insert(entriesList, entry)
    end
    
    -- Sort by userId
    table.sort(entriesList, function(a, b)
        local idA = a:match("^%[(%d+),")
        local idB = b:match("^%[(%d+),")
        return tonumber(idA) < tonumber(idB)
    end)
    
    -- Update cache
    CachedEntries = entriesMap
    
    -- Save to local file (full structure)
    saveToLocalFile(entriesList)
    
    -- Update GitHub with full structure
    local fullContent = formatEntriesForSave(entriesList)
    editFile(fullContent)
    
    task.delay(2, function()
        isUpdating = false
    end)
end

