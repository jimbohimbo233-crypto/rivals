    local NOTIF_W   = 280
    local NOTIF_GAP = 8
    local NOTIF_X   = 16
    local NOTIF_Y   = 16

    local notifStack = {}

    local function rebuildStack()
        local y = NOTIF_Y
        for _, entry in ipairs(notifStack) do
            entry.targetY = y
            tw(entry.frame,
                TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Position = UDim2.new(0, NOTIF_X, 0, y) })
            y = y + entry.frame.AbsoluteSize.Y + NOTIF_GAP
        end
    end

    local function removeNotif(frame)
        for i, entry in ipairs(notifStack) do
            if entry.frame == frame then
                table.remove(notifStack, i)
                break
            end
        end
        tw(frame,
            TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { Position = UDim2.new(0, -NOTIF_W - 20, 0, frame.Position.Y.Offset) })
        task.delay(0.21, function()
            frame:Destroy()
            rebuildStack()
        end)
    end

    --[[
