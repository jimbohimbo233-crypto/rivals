    ListLayout.Parent    = Scroll

    ListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Scroll.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 8)
    end)

    -- ─────────────────────────────────────────────
    --  Tag definitions
    -- ─────────────────────────────────────────────

    local STYLE_TAGS = {
        { id = "closets",  label = "Closets"   },
        { id = "semirage", label = "Semi-Rage" },
        { id = "fullrage", label = "Full Rage" },
    }
    local WEAPON_TAGS = {
        { id = "bow",     label = "Uses Bow"     },
        { id = "daggers", label = "Uses Daggers" },
        { id = "sling",   label = "Uses Sling"   },
        { id = "riot",    label = "Uses Riot"    },
    }

    local playerTagStates = {}

    -- ─────────────────────────────────────────────
    --  Dropdown layout constants
    -- ─────────────────────────────────────────────

    local ITEM_H   = 28
    local SEC_H    = 22
    local DIV_H    = 1
    local PAD      = 6
    local REPORT_H = 30

    local DD_CONTENT_H = PAD
        + SEC_H  + (#STYLE_TAGS  * ITEM_H)
        + PAD + DIV_H + PAD
        + SEC_H  + (#WEAPON_TAGS * ITEM_H)
        + PAD + DIV_H + PAD
        + REPORT_H + PAD

    local DD_MAX_VISIBLE = 200
    local DD_OPEN_H = math.min(DD_CONTENT_H, DD_MAX_VISIBLE)

    -- ─────────────────────────────────────────────
    --  Toggle row
    -- ─────────────────────────────────────────────

    local function makeToggleRow(parent, tagId, label, userId)
        local state = playerTagStates[userId][tagId]

        local Row = Instance.new("Frame")
        Row.Size                   = UDim2.new(1, 0, 0, ITEM_H)
        Row.BackgroundTransparency = 1
        Row.BorderSizePixel        = 0
        Row.Parent                 = parent

        local Track = Instance.new("Frame")
        Track.Size             = UDim2.new(0, 30, 0, 16)
        Track.Position         = UDim2.new(0, 10, 0.5, -8)
        Track.BackgroundColor3 = state and Theme.ToggleOn or Color3.fromRGB(40, 40, 40)
        Track.BorderSizePixel  = 0
        Track.Parent           = Row
        corner(Track, 8)

        local Knob = Instance.new("Frame")
        Knob.Size             = UDim2.new(0, 12, 0, 12)
        Knob.Position         = state
            and UDim2.new(0, 16, 0.5, -6)
            or  UDim2.new(0, 2,  0.5, -6)
        Knob.BackgroundColor3 = Theme.TextWhite
        Knob.BorderSizePixel  = 0
        Knob.Parent           = Track
        corner(Knob, 6)

        local Lbl = Instance.new("TextLabel")
        Lbl.Size                   = UDim2.new(1, -52, 1, 0)
        Lbl.Position               = UDim2.new(0, 48, 0, 0)
        Lbl.BackgroundTransparency = 1
        Lbl.Font                   = Enum.Font.Gotham
        Lbl.TextSize               = 11
        Lbl.TextColor3             = state and Theme.TextWhite or Theme.TextGray
        Lbl.TextXAlignment         = Enum.TextXAlignment.Left
        Lbl.Text                   = label
        Lbl.Parent                 = Row

        local Btn = Instance.new("TextButton")
        Btn.Size                   = UDim2.new(1, 0, 1, 0)
        Btn.BackgroundTransparency = 1
        Btn.Text                   = ""
        Btn.Parent                 = Row

        Btn.MouseEnter:Connect(function()
            Row.BackgroundTransparency = 0
            Row.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
        end)
        Btn.MouseLeave:Connect(function()
            Row.BackgroundTransparency = 1
        end)

        Btn.MouseButton1Click:Connect(function()
            local newState = not playerTagStates[userId][tagId]
            playerTagStates[userId][tagId] = newState

            tw(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
                Position = newState
                    and UDim2.new(0, 16, 0.5, -6)
                    or  UDim2.new(0, 2,  0.5, -6)
            })
            tw(Track, TweenInfo.new(0.15), {
                BackgroundColor3 = newState and Theme.ToggleOn or Color3.fromRGB(40, 40, 40)
            })
            tw(Lbl, TweenInfo.new(0.12), {
                TextColor3 = newState and Theme.TextWhite or Theme.TextGray
            })
        end)
    end

    local function makeSectionHeader(parent, text)
        local Hdr = Instance.new("TextLabel")
        Hdr.Size                   = UDim2.new(1, -16, 0, SEC_H)
        Hdr.BackgroundTransparency = 1
        Hdr.Font                   = Enum.Font.GothamBold
        Hdr.TextSize               = 9
        Hdr.TextColor3             = Theme.AccentBlue
        Hdr.TextXAlignment         = Enum.TextXAlignment.Left
        Hdr.Text                   = string.upper(text)
        Hdr.Parent                 = parent
    end

    local function makeDivider(parent)
        local D = Instance.new("Frame")
        D.Size                   = UDim2.new(1, -20, 0, DIV_H)
        D.BackgroundColor3       = Theme.AccentBlue
        D.BackgroundTransparency = 0.8
        D.BorderSizePixel        = 0
        D.Parent                 = parent
    end

    -- ─────────────────────────────────────────────
    --  Dropdown builder
    -- ─────────────────────────────────────────────

    local function makeDropdown(cardFrame, player)
        local userId = player.UserId

        if not playerTagStates[userId] then
            playerTagStates[userId] = {}
            for _, t in ipairs(STYLE_TAGS)  do playerTagStates[userId][t.id] = false end
            for _, t in ipairs(WEAPON_TAGS) do playerTagStates[userId][t.id] = false end
        end

        local Outer = Instance.new("Frame")
        Outer.Size                   = UDim2.new(1, -10, 0, 0)
        Outer.Position               = UDim2.new(0, 5, 0, CARD_BASE_H + 4)
        Outer.BackgroundColor3       = Theme.BgDeep
        Outer.BackgroundTransparency = 0.04
        Outer.BorderSizePixel        = 0
        Outer.ClipsDescendants       = true
        Outer.Parent                 = cardFrame
        corner(Outer, 12)
        makeStroke(Outer, Theme.AccentBlue, 1, 0.78)

        local ddScroll = Instance.new("ScrollingFrame")
        ddScroll.Size                   = UDim2.new(1, 0, 1, 0)
        ddScroll.BackgroundTransparency = 1
        ddScroll.ScrollBarThickness     = 3
        ddScroll.ScrollBarImageColor3   = Theme.AccentBlue
        ddScroll.BorderSizePixel        = 0
        ddScroll.ScrollingDirection     = Enum.ScrollingDirection.Y
        ddScroll.CanvasSize             = UDim2.new(0, 0, 0, DD_CONTENT_H)
        ddScroll.Parent                 = Outer

        local ddPad = Instance.new("UIPadding")
        ddPad.PaddingLeft  = UDim.new(0, 8)
        ddPad.PaddingRight = UDim.new(0, 8)
        ddPad.Parent       = ddScroll

        local ddList = Instance.new("UIListLayout")
        ddList.Padding   = UDim.new(0, 0)
        ddList.SortOrder = Enum.SortOrder.LayoutOrder
        ddList.Parent    = ddScroll

        local topSpacer = Instance.new("Frame")
        topSpacer.Size                   = UDim2.new(1, 0, 0, PAD)
        topSpacer.BackgroundTransparency = 1
        topSpacer.BorderSizePixel        = 0
        topSpacer.LayoutOrder            = 0
        topSpacer.Parent                 = ddScroll

        local styleHdr = Instance.new("TextLabel")
        styleHdr.Size                   = UDim2.new(1, 0, 0, SEC_H)
        styleHdr.BackgroundTransparency = 1
        styleHdr.Font                   = Enum.Font.GothamBold
        styleHdr.TextSize               = 9
        styleHdr.TextColor3             = Theme.AccentBlue
        styleHdr.TextXAlignment         = Enum.TextXAlignment.Left
        styleHdr.Text                   = "PLAYSTYLE"
        styleHdr.LayoutOrder            = 1
        styleHdr.Parent                 = ddScroll

        for i, tag in ipairs(STYLE_TAGS) do
            local row = Instance.new("Frame")
            row.Size                   = UDim2.new(1, 0, 0, ITEM_H)
            row.BackgroundTransparency = 1
            row.BorderSizePixel        = 0
            row.LayoutOrder            = 1 + i
            row.Parent                 = ddScroll

            local Track = Instance.new("Frame")
            Track.Size             = UDim2.new(0, 30, 0, 16)
            Track.Position         = UDim2.new(0, 2, 0.5, -8)
            Track.BackgroundColor3 = playerTagStates[userId][tag.id] and Theme.ToggleOn or Color3.fromRGB(40, 40, 40)
            Track.BorderSizePixel  = 0
            Track.Parent           = row
            corner(Track, 8)

            local Knob = Instance.new("Frame")
            Knob.Size             = UDim2.new(0, 12, 0, 12)
            Knob.Position         = playerTagStates[userId][tag.id]
                and UDim2.new(0, 16, 0.5, -6)
                or  UDim2.new(0, 2,  0.5, -6)
            Knob.BackgroundColor3 = Theme.TextWhite
            Knob.BorderSizePixel  = 0
            Knob.Parent           = Track
            corner(Knob, 6)

            local Lbl = Instance.new("TextLabel")
            Lbl.Size                   = UDim2.new(1, -42, 1, 0)
            Lbl.Position               = UDim2.new(0, 40, 0, 0)
            Lbl.BackgroundTransparency = 1
            Lbl.Font                   = Enum.Font.Gotham
            Lbl.TextSize               = 11
            Lbl.TextColor3             = playerTagStates[userId][tag.id] and Theme.TextWhite or Theme.TextGray
            Lbl.TextXAlignment         = Enum.TextXAlignment.Left
            Lbl.Text                   = tag.label
            Lbl.Parent                 = row

            local Btn = Instance.new("TextButton")
            Btn.Size                   = UDim2.new(1, 0, 1, 0)
            Btn.BackgroundTransparency = 1
            Btn.Text                   = ""
            Btn.Parent                 = row

            Btn.MouseEnter:Connect(function()
                row.BackgroundTransparency = 0
                row.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
            end)
            Btn.MouseLeave:Connect(function()
                row.BackgroundTransparency = 1
            end)

            local tagId = tag.id
            Btn.MouseButton1Click:Connect(function()
                local ns = not playerTagStates[userId][tagId]
                playerTagStates[userId][tagId] = ns
                tw(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
                    Position = ns and UDim2.new(0,16,0.5,-6) or UDim2.new(0,2,0.5,-6)
                })
                tw(Track, TweenInfo.new(0.15), {
                    BackgroundColor3 = ns and Theme.ToggleOn or Color3.fromRGB(40,40,40)
                })
                tw(Lbl, TweenInfo.new(0.12), {
                    TextColor3 = ns and Theme.TextWhite or Theme.TextGray
                })
            end)
        end

        local div1 = Instance.new("Frame")
        div1.Size                   = UDim2.new(1, 0, 0, PAD + DIV_H + PAD)
        div1.BackgroundTransparency = 1
        div1.BorderSizePixel        = 0
        div1.LayoutOrder            = 10
        div1.Parent                 = ddScroll

        local divLine1 = Instance.new("Frame")
        divLine1.Size                   = UDim2.new(1, 0, 0, 1)
        divLine1.Position               = UDim2.new(0, 0, 0, PAD)
        divLine1.BackgroundColor3       = Theme.AccentBlue
        divLine1.BackgroundTransparency = 0.8
        divLine1.BorderSizePixel        = 0
        divLine1.Parent                 = div1

        local weapHdr = Instance.new("TextLabel")
        weapHdr.Size                   = UDim2.new(1, 0, 0, SEC_H)
        weapHdr.BackgroundTransparency = 1
        weapHdr.Font                   = Enum.Font.GothamBold
        weapHdr.TextSize               = 9
        weapHdr.TextColor3             = Theme.AccentBlue
        weapHdr.TextXAlignment         = Enum.TextXAlignment.Left
        weapHdr.Text                   = "WEAPONS"
        weapHdr.LayoutOrder            = 11
        weapHdr.Parent                 = ddScroll

        for i, tag in ipairs(WEAPON_TAGS) do
            local row = Instance.new("Frame")
            row.Size                   = UDim2.new(1, 0, 0, ITEM_H)
            row.BackgroundTransparency = 1
            row.BorderSizePixel        = 0
            row.LayoutOrder            = 11 + i
            row.Parent                 = ddScroll

            local Track = Instance.new("Frame")
            Track.Size             = UDim2.new(0, 30, 0, 16)
            Track.Position         = UDim2.new(0, 2, 0.5, -8)
            Track.BackgroundColor3 = playerTagStates[userId][tag.id] and Theme.ToggleOn or Color3.fromRGB(40, 40, 40)
            Track.BorderSizePixel  = 0
            Track.Parent           = row
            corner(Track, 8)

            local Knob = Instance.new("Frame")
            Knob.Size             = UDim2.new(0, 12, 0, 12)
            Knob.Position         = playerTagStates[userId][tag.id]
                and UDim2.new(0, 16, 0.5, -6)
                or  UDim2.new(0, 2,  0.5, -6)
            Knob.BackgroundColor3 = Theme.TextWhite
            Knob.BorderSizePixel  = 0
            Knob.Parent           = Track
            corner(Knob, 6)

            local Lbl = Instance.new("TextLabel")
            Lbl.Size                   = UDim2.new(1, -42, 1, 0)
            Lbl.Position               = UDim2.new(0, 40, 0, 0)
            Lbl.BackgroundTransparency = 1
            Lbl.Font                   = Enum.Font.Gotham
            Lbl.TextSize               = 11
            Lbl.TextColor3             = playerTagStates[userId][tag.id] and Theme.TextWhite or Theme.TextGray
            Lbl.TextXAlignment         = Enum.TextXAlignment.Left
            Lbl.Text                   = tag.label
            Lbl.Parent                 = row

            local Btn = Instance.new("TextButton")
            Btn.Size                   = UDim2.new(1, 0, 1, 0)
            Btn.BackgroundTransparency = 1
            Btn.Text                   = ""
            Btn.Parent                 = row

            Btn.MouseEnter:Connect(function()
                row.BackgroundTransparency = 0
                row.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
            end)
            Btn.MouseLeave:Connect(function()
                row.BackgroundTransparency = 1
            end)

            local tagId = tag.id
            Btn.MouseButton1Click:Connect(function()
                local ns = not playerTagStates[userId][tagId]
                playerTagStates[userId][tagId] = ns
                tw(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
                    Position = ns and UDim2.new(0,16,0.5,-6) or UDim2.new(0,2,0.5,-6)
                })
                tw(Track, TweenInfo.new(0.15), {
                    BackgroundColor3 = ns and Theme.ToggleOn or Color3.fromRGB(40,40,40)
                })
                tw(Lbl, TweenInfo.new(0.12), {
                    TextColor3 = ns and Theme.TextWhite or Theme.TextGray
                })
            end)
        end

        local div2 = Instance.new("Frame")
        div2.Size                   = UDim2.new(1, 0, 0, PAD + DIV_H + PAD)
        div2.BackgroundTransparency = 1
        div2.BorderSizePixel        = 0
        div2.LayoutOrder            = 20
        div2.Parent                 = ddScroll

        local divLine2 = Instance.new("Frame")
        divLine2.Size                   = UDim2.new(1, 0, 0, 1)
        divLine2.Position               = UDim2.new(0, 0, 0, PAD)
        divLine2.BackgroundColor3       = Theme.AccentBlue
        divLine2.BackgroundTransparency = 0.8
        divLine2.BorderSizePixel        = 0
        divLine2.Parent                 = div2

        local reportWrap = Instance.new("Frame")
        reportWrap.Size                   = UDim2.new(1, 0, 0, REPORT_H + PAD)
        reportWrap.BackgroundTransparency = 1
        reportWrap.BorderSizePixel        = 0
        reportWrap.LayoutOrder            = 21
        reportWrap.Parent                 = ddScroll

        local ReportBtn = Instance.new("TextButton")
        ReportBtn.Size                   = UDim2.new(1, 0, 0, REPORT_H)
        ReportBtn.BackgroundColor3       = Theme.ReportRed
        ReportBtn.BackgroundTransparency = 0.25
        ReportBtn.BorderSizePixel        = 0
        ReportBtn.Font                   = Enum.Font.GothamBold
        ReportBtn.TextSize               = 11
        ReportBtn.TextColor3             = Color3.fromRGB(255, 190, 190)
        ReportBtn.Text                   = "Send Report"
        ReportBtn.Parent                 = reportWrap
        corner(ReportBtn, 8)
        makeStroke(ReportBtn, Theme.ReportRed, 1, 0.5)

        ReportBtn.MouseEnter:Connect(function()
            tw(ReportBtn, TweenInfo.new(0.12), { BackgroundTransparency = 0.05 })
        end)
        ReportBtn.MouseLeave:Connect(function()
            tw(ReportBtn, TweenInfo.new(0.12), { BackgroundTransparency = 0.25 })
        end)

        ReportBtn.MouseButton1Click:Connect(function()
            local activeTags = {}
        
            for _, tag in ipairs(STYLE_TAGS) do
                if playerTagStates[userId][tag.id] then
                    table.insert(activeTags, string.format('"%s"', tag.label))
                end
            end
            for _, tag in ipairs(WEAPON_TAGS) do
                if playerTagStates[userId][tag.id] then
                    table.insert(activeTags, string.format('"%s"', tag.label))
                end
            end
        
            if #activeTags == 0 then
                Notify:Send({
                    Type = "warning",
                    Title = "No Tags",
                    Description = "Select at least one tag",
                    Duration = 4
                })
                return
            end
        
            -- Build the new entry
            local newEntry = string.format('[%d, %s]', player.UserId, table.concat(activeTags, ", "))
            
            -- Push to both local file and GitHub
            pushEntries({newEntry})
        
            -- Check if this is an update or new report
            local isUpdate = CachedEntries[player.UserId] ~= nil
        
            Notify:Send({
                Type        = "warning",
                Title       = isUpdate and "Report Updated" or "Report Added",
                Description = player.Name .. "\n" .. table.concat(activeTags, ", "),
                Duration    = 5
            })
        end)

        local isOpen = false
        local tweenInfo = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        local function toggle()
            isOpen = not isOpen
            local targetCardH  = isOpen and (CARD_BASE_H + 4 + DD_OPEN_H) or CARD_BASE_H
            local targetOuterH = isOpen and DD_OPEN_H or 0

            tw(Outer,     tweenInfo, { Size = UDim2.new(1, -10, 0, targetOuterH) })
            tw(cardFrame, tweenInfo, { Size = UDim2.new(1, 0,   0, targetCardH)  })
        end

        return Outer, toggle
    end

    -- ─────────────────────────────────────────────
    --  Player card builder
    -- ─────────────────────────────────────────────

    local playerCards = {}

    local function makePlayerCard(player)
        if player == LocalPlayer then return end
        if playerCards[player.UserId] then return end

        local Card = Instance.new("Frame")
        Card.Name             = player.Name
        Card.Size             = UDim2.new(1, 0, 0, CARD_BASE_H)
        Card.BackgroundColor3 = Theme.BgDark
        Card.BorderSizePixel  = 0
        Card.ClipsDescendants = false
        Card.Parent           = Scroll
        corner(Card, 14)
        makeStroke(Card, Theme.AccentBlue, 1, 0.84)

        local SideBar = Instance.new("Frame")
        SideBar.Size                   = UDim2.new(0, 2, 0, CARD_BASE_H - 16)
        SideBar.Position               = UDim2.new(0, 0, 0, 8)
        SideBar.BackgroundColor3       = Theme.AccentBlue
        SideBar.BackgroundTransparency = 0.3
        SideBar.BorderSizePixel        = 0
        SideBar.Parent                 = Card
        corner(SideBar, 2)

        local AvatarBg = Instance.new("Frame")
        AvatarBg.Size             = UDim2.new(0, 44, 0, 44)
        AvatarBg.Position         = UDim2.new(0, 10, 0, 10)
        AvatarBg.BackgroundColor3 = Theme.AccentDark
        AvatarBg.BorderSizePixel  = 0
        AvatarBg.Parent           = Card
        corner(AvatarBg, 22)

        local Avatar = Instance.new("ImageLabel")
        Avatar.Size                   = UDim2.new(1, 0, 1, 0)
        Avatar.BackgroundTransparency = 1
        Avatar.Image                  = "rbxthumb://type=AvatarHeadShot&id=" .. player.UserId .. "&w=150&h=150"
        Avatar.Parent                 = AvatarBg
        corner(Avatar, 22)

        local NameLabel = Instance.new("TextLabel")
        NameLabel.Size                   = UDim2.new(1, -116, 0, 18)
        NameLabel.Position               = UDim2.new(0, 62, 0, 10)
        NameLabel.BackgroundTransparency = 1
        NameLabel.Font                   = Enum.Font.GothamBold
        NameLabel.TextSize               = 12
        NameLabel.TextColor3             = Theme.TextWhite
        NameLabel.TextXAlignment         = Enum.TextXAlignment.Left
        NameLabel.Text                   = player.Name
        NameLabel.Parent                 = Card

        local DisplayLabel = Instance.new("TextLabel")
        DisplayLabel.Size                   = UDim2.new(1, -116, 0, 14)
        DisplayLabel.Position               = UDim2.new(0, 62, 0, 30)
        DisplayLabel.BackgroundTransparency = 1
        DisplayLabel.Font                   = Enum.Font.Gotham
        DisplayLabel.TextSize               = 10
        DisplayLabel.TextColor3             = Theme.TextDim
        DisplayLabel.TextXAlignment         = Enum.TextXAlignment.Left
        DisplayLabel.Text                   = player.DisplayName ~= player.Name
            and player.DisplayName
            or  "@" .. player.Name
        DisplayLabel.Parent                 = Card

        local ActionBtn = Instance.new("TextButton")
        ActionBtn.Size                   = UDim2.new(0, 38, 0, 22)
        ActionBtn.Position               = UDim2.new(1, -48, 0, 21)
        ActionBtn.BackgroundColor3       = Theme.AccentDark
        ActionBtn.BackgroundTransparency = 0.2
        ActionBtn.BorderSizePixel        = 0
        ActionBtn.Font                   = Enum.Font.GothamBold
        ActionBtn.TextSize               = 16
        ActionBtn.TextColor3             = Theme.AccentLight
        ActionBtn.Text                   = "⋯"
        ActionBtn.ZIndex                 = 5
        ActionBtn.Parent                 = Card
        corner(ActionBtn, 8)

        local _, toggleDD = makeDropdown(Card, player)

        ActionBtn.MouseButton1Click:Connect(toggleDD)

        Card.MouseEnter:Connect(function()
            tw(Card, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(26, 26, 26) })
        end)
        Card.MouseLeave:Connect(function()
            tw(Card, TweenInfo.new(0.15), { BackgroundColor3 = Theme.BgDark })
        end)

        playerCards[player.UserId] = Card
        CountBadge.Text = tostring(#Players:GetPlayers() - 1)
    end

    local function removePlayerCard(player)
        local card = playerCards[player.UserId]
        if card then
            card:Destroy()
            playerCards[player.UserId] = nil
        end
        playerTagStates[player.UserId] = nil
        CountBadge.Text = tostring(math.max(0, #Players:GetPlayers() - 1))
    end

    -- Load the initial cheater list
    getCheaterList()

    for _, p in ipairs(Players:GetPlayers()) do
        makePlayerCard(p)
    end

    Players.PlayerAdded:Connect(function(p)
        task.wait(0.3)
        makePlayerCard(p)
    end)
    
    Players.PlayerRemoving:Connect(function(p)
        removePlayerCard(p)
    end)

    -- ══════════════════════════════════════════════
    --  EXPOSE GLOBALS
    -- ══════════════════════════════════════════════

    _G.Notify     = Notify
    _G.PlayerTags = playerTagStates

    print("[GUI Framework] Loaded — ';' toggles the player HUD | notifications always on")
end
