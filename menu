                ["Content-Type"] = "application/json",
            },
            Body = HttpService:JSONEncode({
                message = "append new reports",
                content = base64Encode(newContent),
                sha = getFileSha(),
                branch = BRANCH
            })
        })
        print("GitHub:", res.StatusCode)
    end

    --// CACHE SYSTEM
    local CachedEntries = {}
    local isUpdating = false

    -- fetch the raw file content and parse existing entries
    local function fetchEntries()
        if #CachedEntries > 0 then return CachedEntries end

        local raw = game:HttpGet(RAW_URL)
        local content = raw:match("%[%[(.-)%]%]") or ""

        content = content:gsub("\r", "")

        local entries = {}
        for line in content:gmatch("[^\n]+") do
            line = line:match("^%s*(.-)%s*$")
            if line ~= "" then
                table.insert(entries, line)
            end
        end

        CachedEntries = entries
        return CachedEntries
    end

    -- append new reports safely onto the existing file
    -- append new reports safely onto the existing file
local function pushEntries(newReports)
    if isUpdating then return end
    isUpdating = true

    -- fetch latest raw content
    local rawText = game:HttpGet(RAW_URL)

    local startIdx, endIdx = rawText:find("%[%[")
    local closeIdx = rawText:find("%]%]", endIdx)
    if not startIdx or not closeIdx then
        warn("Could not find cheaters block in GitHub file")
        isUpdating = false
        return
    end

    local existingContent = rawText:sub(endIdx + 1, closeIdx - 1)
    existingContent = existingContent:gsub("\r", "")

    -- Parse existing entries into a table with userId as key for easy lookup
    local entriesMap = {}
    local entriesList = {}
    
    for line in existingContent:gmatch("[^\n]+") do
        line = line:match("^%s*(.-)%s*$")
        if line ~= "" then
            -- Extract userId from the entry
            local userId = line:match("^%[(%d+),")
            if userId then
                userId = tonumber(userId)
                entriesMap[userId] = line
                table.insert(entriesList, {userId = userId, line = line})
            end
        end
    end

    -- Update or add new entries
    for _, report in ipairs(newReports) do
        -- Extract userId from the report
        local userId = report:match("^%[(%d+),")
        if userId then
            userId = tonumber(userId)
            -- Ensure the entry ends with a comma
            if not report:match(",$") then
                report = report .. ","
            end
            entriesMap[userId] = report
        end
    end

    -- Rebuild the entries list with proper formatting
    local lines = {}
    for userId, entry in pairs(entriesMap) do
        table.insert(lines, entry)
        -- Update cache
        CachedEntries[userId] = entry
    end
    
    -- Sort entries by userId for consistent ordering
    table.sort(lines, function(a, b)
        local idA = a:match("^%[(%d+),")
        local idB = b:match("^%[(%d+),")
        return tonumber(idA) < tonumber(idB)
    end)

    -- Add a trailing comma to all entries except the last one
    for i = 1, #lines do
        if i < #lines then
            if not lines[i]:match(",$") then
                lines[i] = lines[i] .. ","
            end
        else
            -- Last entry should not have a comma
            lines[i] = lines[i]:gsub(",$", "")
        end
    end

    -- Rebuild the cheaters block inside original raw content
    local newContent = rawText:sub(1, endIdx) ..
                       table.concat(lines, "\n") ..
                       rawText:sub(closeIdx)

    editFile(newContent)

    task.delay(2, function()
        isUpdating = false
    end)
end

